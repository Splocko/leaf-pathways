# ─────────────────────────────────────────────────────────────
# LEAF Pathways — environment variables
# Copy to `.env.local` and fill in. All features degrade gracefully
# if a value is missing (empty states / disabled writes).
# ─────────────────────────────────────────────────────────────

# Supabase (REQUIRED for live events, blog, webinars, community signup, admin)
# Same project the site already uses: cueuwyazwjikiogxsbrs
NEXT_PUBLIC_SUPABASE_URL=https://cueuwyazwjikiogxsbrs.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Server-side only — NEVER expose to the client.
# Required for the competition results pages (service-role reads).
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Upstash Redis — API rate limiting middleware (OPTIONAL; fails open if absent)
UPSTASH_REDIS_REST_URL=your_upstash_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# Resend — newsletter subscribe route /api/newsletter (REQUIRED for newsletter)
RESEND_API_KEY=your_resend_api_key_here
# Optional Resend extras:
RESEND_SEGMENT_ID=your_resend_segment_id_here
RESEND_FROM_EMAIL=LEAF Pathways <noreply@leafpathways.com>
RESEND_WELCOME_TEMPLATE_ID=your_template_id_here
